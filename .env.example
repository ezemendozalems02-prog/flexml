# ============================================================
# FlexControl — Variables de entorno (ejemplo, SIN valores reales)
# Copiar a .env.local y completar. Nunca subir secretos al repo.
# ============================================================

# URL pública de la aplicación (sin barra final)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor. NUNCA exponer con prefijo NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# --- Mercado Libre (app creada en developers.mercadolibre.com.ar) ---
MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=
# Debe coincidir exactamente con la Redirect URI configurada en la app de ML
MERCADOLIBRE_REDIRECT_URI=http://localhost:3000/api/oauth/mercadolibre/callback
# Usar adaptador simulado mientras no haya credenciales reales (true/false)
MERCADOLIBRE_USE_MOCK=true

# --- Cifrado de tokens (AES-256-GCM) ---
# Generar con: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Jobs programados (/api/cron/*): protege el endpoint con este secreto ---
# Vercel Cron está deshabilitado por ahora (plan Hobby = solo 1x/día); disparar
# estos endpoints a mano o desde un scheduler externo mientras tanto.
CRON_SECRET=

# --- Webhook (validación adicional del endpoint de notificaciones) ---
WEBHOOK_SECRET=

# --- Correo transaccional ---
RESEND_API_KEY=

# --- Mapas (uno de los dos) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Monitoreo (opcional) ---
SENTRY_DSN=
